# 1. Histórico Oficial (Alimentado semanalmente)
# Propositalmente etou ignirando o primeiro paredão porque as fontes não haviam
# se consolidade ainda, e o engajamento era menor, o que geraria maior ruído 
historico <- tibble(
  Paredao = c("P2 - Matheus", "P3 - Brígido", "P4 - Sarah", 
              "P5 - Marcelo", "P6 - Maxiane", "P7 - Breno", 
              "P8 - Babu"),
  
  Resultado_Oficial = c(79.48, 77.88, 69.13, 68.56, 63.21, 54.56, 68.62),
  
  # Fontes do Instagram
  Insta_Aaron_Tura = c(75.00, 69.00, 60.00, 63.00, 58.00, 44.00, 62.00),
  Insta_Parciais_Of_Reality = c(78.00, 76.00, 73.00, 73.00, 65.00, 51.53, 79.00),
  Media_Insta = c(77.81, 73.20, 69.33, 65.25, 65.07, 53.43, 70.33),
  Media_YT = c(92.10, 89.50, 81.20, 81.00, 75.80, 66.90, 57.63),
  X_Choquei = c(78.90, 78.00, 72.20, 74.60, 67.20, 49.80, 77.77),
  Media_TW = c(80.74, 74.55, 66.04, 78.25, 68.20, 48.99, 77.77)
)

# 2. Dados do atual
novo_paredao <- tibble(
  Fonte = c("Media_Insta", "Insta_Parciais_Of_Reality"),
  Babu = c(70.33, 79),
  Milena = c(27.93, 20),
  Chaiany = c(1.73, 1)
)

# 3. # Execução do modelo
resultado <- ensemble_calibrado_bbb(
  df_historico = historico, 
  df_novo_paredao = novo_paredao
)


# ——————————————————————————————————————————————————————————————————————————————
# Criando gráfico com histórico ————————————————————————————————————————————————
# ——————————————————————————————————————————————————————————————————————————————

# Parcial 1
resultado$Projecao %>%
  # pivotando para grafico, mandando colunas para linha
  pivot_longer(cols = everything(), names_to = "Concorrente", 
               values_to = "Projecao") %>%
  # Organizando ordem do factor, Babu, Milena e Chaiany
  mutate(Concorrente = factor(Concorrente, 
                              levels = c("Babu", "Milena", "Chaiany"))) %>%
  ggplot(aes(x = Concorrente, y = Projecao, fill = Concorrente)) +
  geom_bar(stat = "identity", position = "dodge") +
  # adicionando geom_text para mostrar os valores em cima das barras
  geom_text(aes(label = paste0(scales::number(Projecao, decimal.mark = ",", 
                                              accuracy = 0.01), "%")), 
            position = position_dodge(width = 0.9), vjust = -0.5) +
  labs(title = "BBB 26 - 8º Paredão: Estimativa de Percentual de Eliminação",
       subtitle = "Quem você quer eliminar?",
       caption = "Erro máximo histórico observado: 3,42 p.p.
       Atualização: Terça-feira, 18h",
       x = "", 
       y = "") +
  theme_minimal() +
  theme(legend.position = "none",
        plot.caption = element_text(size = 8, face = "italic"),
        legend.text = element_text(size = 10),
        plot.subtitle = element_text(size = 12),
        plot.title = element_text(size = 16, face = "bold"),
        axis.text.y = element_text(size = 10),
        axis.text.x = element_text(size = 14, face = "bold")) +
  # aumentando a escala de y para ir até 100
  scale_y_continuous(limits = c(0, 100)) +
  # usando paleta pastel1
  scale_fill_brewer(palette = "Pastel1")

analise$Modelo_Vencedor$Pesos_Atribuidos

